# Swarm Trader - Environment Configuration
# Copy this file to .env and fill in your API keys

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=swarm_user
DB_PASSWORD=swarm_password_2026
DB_NAME=swarm_trader

# ClickHouse (optional - for orderbook data)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=swarm_user
CLICKHOUSE_PASSWORD=swarm_password_2026
CLICKHOUSE_DB=swarm_orderbook

# Redis (optional - for caching)
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# API KEYS - FREE TIER (Already configured!)
# ============================================

# FRED API (Federal Reserve Economic Data) - FREE
# 120,000 calls/day - Already configured!
FRED_API_KEY=8101e05db182ccd505bc50920a8f097c

# Alpha Vantage - FREE
# 25 calls/day (free tier) - Already configured!
ALPHA_VANTAGE_KEY=CS37J2Y39A7P4BHS

# ============================================
# API KEYS - OPTIONAL (Add your own)
# ============================================

# Binance API (for real-time OHLCV)
# Get from: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Coinglass API (for Futures data - Funding, OI, Liquidation)
# Get from: https://coinglass.com/api
COINGLASS_API_KEY=

# Glassnode API (for On-Chain data - SOPR, MVRV, Exchange flows)
# Get from: https://glassnode.com (Free tier available)
GLASSNODE_API_KEY=

# LunarCrush API (for Social Sentiment)
# Get from: https://lunarcrush.com/api
LUNARCRUSH_API_KEY=

# CryptoPanic API (for News - FREE)
# Get from: https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=

# Reddit API (for Reddit sentiment)
# Get from: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Twitter/X API (optional)
# Get from: https://developer.twitter.com/
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=

# ============================================
# TRADING CONFIGURATION (For later use)
# ============================================

# Telegram Bot (for alerts)
# Get from: @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Broker Configuration (Testnet by default)
# For Binance Testnet: https://testnet.binancefuture.com
BINANCE_TESTNET=true
BINANCE_API_KEY_TESTNET=
BINANCE_SECRET_KEY_TESTNET=

# ============================================
# SWARM CONFIGURATION
# ============================================

# Number of agents to run
SWARM_AGENT_COUNT=5

# Consensus threshold (0.0 - 1.0)
SWARM_CONSENSUS_THRESHOLD=0.25

# Risk management
MAX_POSITION_SIZE=0.1  # 10% of portfolio
STOP_LOSS_PCT=0.02     # 2% stop loss
TAKE_PROFIT_PCT=0.04   # 4% take profit (2:1 R:R)

# ============================================
# LOGGING
# ============================================

LOG_LEVEL=INFO
LOG_FILE=logs/swarm.log
